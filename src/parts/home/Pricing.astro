<section class="relative py-28 bg-white overflow-hidden">

  <!-- BACKGROUND GLOW -->
  <div class="absolute inset-0 pointer-events-none">

    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[400px] bg-blue-50 blur-3xl opacity-40"></div>

    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-white to-transparent"></div>

  </div>

  <div class="relative container mx-auto px-4">

    <!-- HEADER -->
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold tracking-wider text-blue-600 uppercase">
        {t.eyebrow}
      </p>

      <h2 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-[#0f172a]">
        {t.title}
      </h2>

      <p class="mt-6 text-gray-600 text-base md:text-lg">
        {t.intro}
      </p>
    </div>

    <!-- DESKTOP / TABLET -->
    <div class="hidden md:grid lg:grid-cols-3 md:grid-cols-2 gap-10 mt-20 items-stretch">

      {t.plans.map((plan) => (
        <div
          class={`relative flex flex-col justify-between p-8 rounded-2xl transition-all duration-300
          ${
            plan.highlight
              ? "bg-[#0f172a] text-white shadow-[0_25px_70px_rgba(15,23,42,0.30)] scale-[1.05] z-10"
              : "bg-white border border-gray-200 shadow-[0_10px_30px_rgba(15,23,42,0.06)] hover:shadow-[0_20px_50px_rgba(15,23,42,0.10)]"
          }`}
        >

          <!-- subtle glow for highlight -->
          {plan.highlight && (
            <div class="absolute -inset-1 bg-blue-500/10 blur-2xl rounded-2xl"></div>
          )}

          <div class="relative z-10">

            <h3 class="text-lg font-semibold">
              {plan.name}
            </h3>

            <p class={`mt-4 text-3xl font-bold ${plan.highlight ? "text-white" : "text-[#0f172a]"}`}>
              {plan.price}
            </p>

            <p class={`mt-4 text-sm leading-relaxed ${plan.highlight ? "text-gray-300" : "text-gray-600"}`}>
              {plan.desc}
            </p>

            <ul class="mt-6 space-y-3 text-sm">
              {plan.features.map((f) => (
                <li class={`flex items-start gap-2 ${plan.highlight ? "text-gray-300" : "text-gray-600"}`}>
                  <span class="mt-[5px] w-1.5 h-1.5 rounded-full bg-current"></span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>

          </div>

        </div>
      ))}

    </div>

    <!-- MOBILE -->
<div class="md:hidden mt-16 space-y-6">

  {t.plans.map((plan) => (
    <div
      class={`relative p-6 rounded-2xl transition-all duration-300
      ${
        plan.highlight
          ? "bg-[#0f172a] text-white shadow-[0_15px_40px_rgba(15,23,42,0.25)] scale-[1.02]"
          : "bg-white border border-gray-200 shadow-[0_8px_20px_rgba(15,23,42,0.06)]"
      }`}
    >

      <!-- subtle highlight glow -->
      {plan.highlight && (
        <div class="absolute -inset-1 bg-blue-500/10 blur-2xl rounded-2xl"></div>

      )}
      <div class="relative z-10">

        <h3 class="text-lg font-semibold">
          {plan.name}
        </h3>

        <p class="mt-3 text-2xl font-bold">
          {plan.price}
        </p>

        <p class={`mt-3 text-sm leading-relaxed ${plan.highlight ? "text-gray-300" : "text-gray-600"}`}>
          {plan.desc}
        </p>

        <ul class="mt-5 space-y-2 text-sm">
          {plan.features.map((f) => (
            <li class="flex items-start gap-2">
              <span class="mt-[5px] w-1.5 h-1.5 rounded-full bg-current"></span>
              <span>{f}</span>
            </li>
          ))}
        </ul>

      </div>

    </div>
  ))}

</div>

  </div>
</section>
