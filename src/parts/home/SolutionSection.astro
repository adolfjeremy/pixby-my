---
import { solutionContent } from "../../i18n/home/Solution";
type Lang = keyof typeof solutionContent; // "en" | "my"

const { lang = "en" } = Astro.props as { lang?: Lang };

const t = solutionContent[lang];
---

<section class="relative py-24 bg-[#f8fafc] overflow-hidden">

  <!-- subtle background accent -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-100 blur-3xl opacity-40 rounded-full"></div>

  <div class="relative container mx-auto px-4">

    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- LEFT SIDE (Content Block) -->
      <div class="max-w-xl">

        <p class="text-sm font-semibold tracking-wider text-blue-600 uppercase">
          {t.eyebrow}
        </p>

        <h2 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-tight text-[#0f172a]">
          {t.title}
        </h2>

        <p class="mt-6 text-gray-600 text-base md:text-lg leading-relaxed">
          {t.intro}
        </p>

      </div>

      <!-- RIGHT SIDE (Timeline Framework) -->
      <div class="relative pl-8 border-l border-gray-300 space-y-14">

        {t.pillars.map((item) => (
          <div class="relative group">

            <!-- dot -->
            <div class="absolute -left-[10px] top-2 w-4 h-4 bg-blue-600 rounded-full shadow-md group-hover:scale-110 transition-transform"></div>

            <div class="ms-4">
              <span class="text-sm font-semibold text-blue-600 tracking-widest">
                {item.number}
              </span>

              <h3 class="mt-2 text-xl font-semibold text-[#0f172a]">
                {item.title}
              </h3>

              <p class="mt-3 text-sm text-gray-600 leading-relaxed max-w-md">
                {item.desc}
              </p>
            </div>

          </div>
        ))}

      </div>

    </div>

  </div>
</section>
