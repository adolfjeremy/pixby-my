---
import {solutionContent} from "../../i18n/home/Solution";
type Lang = keyof typeof solutionContent; // "en" | "my"

const { lang = "en" } = Astro.props as { lang?: Lang };

const t = solutionContent[lang];
---

<section class="py-16 md:py-24">
  <div class="container mx-auto px-4">

    <!-- HEADER -->
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-medium text-blue-600 mb-3">
        {t.eyebrow}
      </p>

      <h2 class="text-2xl md:text-3xl lg:text-4xl font-semibold leading-snug">
        {t.title}
      </h2>

      <p class="mt-4 text-gray-600 text-base md:text-lg">
        {t.intro}
      </p>
    </div>

    <!-- PILLARS -->
    <div class="mt-14 grid gap-8 md:grid-cols-3">

      {t.pillars.map((item, index) => (
        <div class="relative">

          <!-- Number Badge -->
          <div class="text-5xl font-semibold text-gray-100 absolute -top-6 left-0 select-none">
            0{index + 1}
          </div>

          <div class="relative bg-white p-6 rounded-lg border border-gray-200 shadow-sm hover:shadow-md transition-shadow">

            <h3 class="text-lg font-semibold mb-3">
              {item.title}
            </h3>

            <p class="text-sm text-gray-600 leading-relaxed">
              {item.desc}
            </p>

          </div>

        </div>
      ))}

    </div>

  </div>
</section>