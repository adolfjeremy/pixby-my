---
import { problemContent } from "../../i18n/home/Problem";
type Lang = keyof typeof problemContent; // "en" | "my"

const { lang = "en" } = Astro.props as { lang?: Lang };
const t = problemContent[lang]; // now `lang` is correctly typed
---

<section class="relative py-24 bg-[#0f172a] text-white overflow-hidden">
  <!-- Radial Glow Background -->
  <div
    class="absolute -top-60 left-1/2 -translate-x-1/2 w-[900px] h-[900px] bg-blue-600/20 blur-3xl rounded-full"
  >
  </div>

  <div class="relative container mx-auto px-4">
    <!-- HEADER -->
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold tracking-wider text-blue-400 uppercase">
        {t.eyebrow}
      </p>

      <h2
        class="mt-4 text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-tight"
      >
        {t.title}
      </h2>

      <p class="mt-6 text-gray-300 text-base md:text-lg leading-relaxed">
        {t.intro}
      </p>
    </div>

    <!-- PROBLEM GRID -->
    <div class="mt-16 grid gap-8 md:grid-cols-2">
      {
        t.problems.map((item, index) => (
          <div class="group relative p-8 rounded-xl bg-white/5 backdrop-blur-md border border-white/10 hover:bg-white/10 transition-all duration-300">
            <span class="text-blue-400 text-sm font-semibold tracking-widest">
              {String(index + 1).padStart(2, "0")}
            </span>

            <h3 class="mt-4 text-xl font-semibold text-white">{item.title}</h3>

            <p class="mt-4 text-sm text-gray-300 leading-relaxed">
              {item.desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
