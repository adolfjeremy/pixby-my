---
type Lang = "en" | "my";
const { lang = "en" } = Astro.props as { lang?: Lang };

import { processContent } from "../../i18n/home/process";

const t = processContent[lang];
---

<section class="relative py-28 bg-gradient-to-b from-white to-[#f3f6fb] overflow-hidden">

  <!-- DEPTH BACKGROUND LAYER -->
  <div class="absolute inset-0 pointer-events-none">

    <!-- top light field -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[400px] bg-blue-50 blur-3xl opacity-40"></div>

    <!-- bottom soft fade -->
    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-white to-transparent"></div>

  </div>

  <div class="relative container mx-auto px-4">

    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold tracking-wider text-blue-600 uppercase">
        {t.eyebrow}
      </p>

      <h2 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-[#0f172a]">
        {t.title}
      </h2>

      <p class="mt-6 text-gray-600 text-base md:text-lg">
        {t.intro}
      </p>
    </div>

    <!-- DESKTOP -->
    <div class="hidden lg:block mt-20 relative">

      <!-- Connector Surface -->
      <div class="absolute top-6 left-0 right-0 h-px overflow-hidden">
        <div class="w-full h-full bg-gradient-to-r from-gray-100 via-gray-300 to-gray-100"></div>
        <div class="shimmer-line"></div>
      </div>

      <div class="grid grid-cols-5 gap-8 relative">

        {t.steps.map((step) => (
          <div class="flex flex-col items-center text-center relative">

            <!-- Step Number -->
            <div class="relative z-10 w-12 h-12 flex items-center justify-center rounded-full bg-white border border-gray-300 text-sm font-semibold text-[#0f172a] shadow-[0_4px_10px_rgba(15,23,42,0.05)]">
              {step.number}
            </div>

            <!-- Card -->
            <div class="mt-8 py-6 px-6 bg-white rounded-2xl 
                        shadow-[0_8px_30px_rgba(15,23,42,0.06)]
                        hover:shadow-[0_15px_45px_rgba(15,23,42,0.10)]
                        hover:-translate-y-1
                        transition-all duration-300 
                        w-full h-full flex flex-col justify-center items-center">

              <h3 class="text-lg font-semibold text-[#0f172a]">
                {step.title}
              </h3>

              <p class="mt-4 text-sm text-gray-600 leading-relaxed">
                {step.desc}
              </p>

            </div>

          </div>
        ))}

      </div>

    </div>

    <!-- TABLET -->
    <div class="hidden md:grid lg:hidden grid-cols-2 gap-10 mt-16">

      {t.steps.map((step) => (
        <div class="relative p-8 bg-white rounded-2xl 
                    shadow-[0_8px_30px_rgba(15,23,42,0.06)]
                    hover:shadow-[0_15px_45px_rgba(15,23,42,0.10)]
                    transition-all duration-300">

          <div class="flex items-center gap-4 mb-6">
            <div class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-300 text-sm font-semibold bg-white shadow-sm">
              {step.number}
            </div>

            <div class="h-px flex-1 bg-gradient-to-r from-gray-200 via-gray-300 to-gray-200"></div>
          </div>

          <h3 class="text-lg font-semibold text-[#0f172a]">
            {step.title}
          </h3>

          <p class="mt-4 text-sm text-gray-600 leading-relaxed">
            {step.desc}
          </p>

        </div>
      ))}

    </div>

    <!-- MOBILE -->
    <div class="md:hidden mt-16 relative">

      <!-- Vertical Spine -->
      <div class="absolute left-5 top-0 bottom-0 w-px overflow-hidden">
        <div class="w-full h-full bg-gradient-to-b from-gray-200 via-gray-300 to-gray-200"></div>
        <div class="mobile-shimmer"></div>
      </div>

      <div class="space-y-12">

        {t.steps.map((step) => (
          <div class="relative pl-16">

            <div class="absolute left-0 top-1 w-10 h-10 flex items-center justify-center rounded-full bg-white border border-gray-300 text-sm font-semibold shadow-[0_4px_10px_rgba(15,23,42,0.05)]">
              {step.number}
            </div>

            <h3 class="text-lg font-semibold text-[#0f172a]">
              {step.title}
            </h3>

            <p class="mt-3 text-sm text-gray-600 leading-relaxed">
              {step.desc}
            </p>

          </div>
        ))}

      </div>

    </div>

  </div>
</section>


<style>
    .shimmer-line {
  position: absolute;
  top: 0;
  left: -20%;
  width: 20%;
  height: 100%;

  background: linear-gradient(
    90deg,
    transparent,
    rgba(37, 99, 235, 1),
    transparent
  );

  animation: shimmerMove 6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  filter: blur(0.5px);
}

@keyframes shimmerMove {
  0% { left: -20%; opacity: 0; }
  15% { opacity: 1; }
  85% { opacity: 1; }
  100% { left: 100%; opacity: 0; }
}

.mobile-shimmer {
  position: absolute;
  top: -20%;
  left: 0;
  width: 100%;
  height: 20%;

  background: linear-gradient(
    180deg,
    transparent,
    rgba(37, 99, 235, 1)    
    transparent
  );

  animation: mobileShimmer 6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes mobileShimmer {
  0% { top: -20%; opacity: 0; }
  15% { opacity: 1; }
  85% { opacity: 1; }
  100% { top: 100%; opacity: 0; }
}
</style>